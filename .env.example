# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="SEO Trust Path Analysis Service"
APP_VERSION="1.0.0"
DEBUG=false

# ── Redis ──────────────────────────────────────────────────────────────────────
# 格式: rediss://default:<password>@<host>:<port>/<db>
REDIS_URL=rediss://default:your_redis_password@your_redis_host:6379/0

# ── Dify ───────────────────────────────────────────────────────────────────────
# 在 Dify 控制台生成: https://cloud.dify.ai → 进入应用 → API → 生成
DIFY_API_KEY=app-your_dify_api_key
DIFY_API_URL=https://api.dify.ai/v1
DIFY_WORKFLOW_ID=your_dify_workflow_id
DIFY_STREAM_TIMEOUT=120
DIFY_RETRY=3

# ── SerpAPI ────────────────────────────────────────────────────────────────────
# 在控制台生成: https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key

# ── Concurrency & Rate Limiting ───────────────────────────────────────────────
MAX_CONCURRENT_REQUESTS=10
RATE_LIMIT_PER_MINUTE=10

# ── Scraper ────────────────────────────────────────────────────────────────────
SCRAPER_TIMEOUT=30
SCRAPER_RETRY=3
SCRAPER_MIN_CONTENT_LENGTH=300

# Jina Reader — 留空则使用免费额度
JINA_API_KEY=

# Firecrawl — 付费备用抓取器
# 在控制台生成: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key
FIRECRAWL_API_URL=https://api.firecrawl.dev/v1

# ── Dify Global Rate Limiting (token bucket) ──────────────────────────────────
# 按照你的 OpenAI / Dify RPM 配额调整
DIFY_RPM_CAPACITY=60
DIFY_RPM_REFILL=60
DIFY_RPM_INTERVAL=60

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
TASK_RESULT_TTL=86400
SCRAPER_CACHE_TTL=600
REPORT_CACHE_TTL=600

# ── CORS ───────────────────────────────────────────────────────────────────────
# 逗号分隔或 JSON 数组: '["https://yourfrontend.com"]'
CORS_ORIGINS=["https://yourfrontend.com"]

# ── Flower 监控面板登录 ────────────────────────────────────────────────────────
# 请使用强密码，不要使用默认值
FLOWER_USER=admin
FLOWER_PASSWORD=your_strong_password_here
